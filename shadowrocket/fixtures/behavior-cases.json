{
  "schema_version": 1,
  "cases": [
    {
      "name": "Bilibili splash payload is emptied",
      "script": "startup-ad-clean.js",
      "url": "https://app.bilibili.com/x/v2/splash/list",
      "body": {
        "code": 0,
        "data": {
          "list": [{ "id": 1 }],
          "show": [{ "id": 2 }]
        }
      },
      "assertions": [
        { "path": "bodyJson.data.list.length", "equals": 0 },
        { "path": "bodyJson.data.max_time", "equals": 0 }
      ]
    },
    {
      "name": "Bilibili feed ads are filtered",
      "script": "startup-ad-clean.js",
      "url": "https://app.bilibili.com/x/v2/feed/index",
      "body": {
        "data": {
          "items": [
            { "id": 1, "title": "normal" },
            { "id": 2, "is_ad": true },
            { "id": 3, "card_goto": "ad_web" }
          ]
        }
      },
      "assertions": [
        { "path": "bodyJson.data.items.length", "equals": 1 },
        { "path": "bodyJson.data.items.0.id", "equals": 1 }
      ]
    },
    {
      "name": "Bilibili tab entries are narrowed",
      "script": "startup-ad-clean.js",
      "url": "https://app.bilibili.com/x/resource/show/tab/v2",
      "body": {
        "data": {
          "top": [
            { "id": 1, "name": "消息", "pos": 9 },
            { "id": 2, "name": "游戏中心", "pos": 10 },
            { "id": 3, "name": "历史", "pos": 11 }
          ],
          "bottom": [
            { "id": 4, "name": "首页", "pos": 9 },
            { "id": 5, "name": "发布", "pos": 10 },
            { "id": 6, "name": "会员购", "tab_id": "mall", "pos": 11 },
            { "id": 7, "name": "我的", "pos": 12 }
          ]
        }
      },
      "assertions": [
        { "path": "bodyJson.data.top.length", "equals": 2 },
        { "path": "bodyJson.data.top.0.name", "equals": "消息" },
        { "path": "bodyJson.data.top.1.name", "equals": "历史" },
        { "path": "bodyJson.data.top.1.pos", "equals": 2 },
        { "path": "bodyJson.data.bottom.length", "equals": 2 },
        { "path": "bodyJson.data.bottom.0.name", "equals": "首页" },
        { "path": "bodyJson.data.bottom.1.name", "equals": "我的" },
        { "path": "bodyJson.data.bottom.1.pos", "equals": 2 }
      ]
    },
    {
      "name": "Generic startup cleanup avoids unrelated content",
      "script": "startup-ad-clean.js",
      "url": "https://example.com/splash/list",
      "body": {
        "data": {
          "user": { "name": "ok" },
          "ad_list": [{ "id": 1 }],
          "interval": 8
        }
      },
      "assertions": [
        { "path": "bodyJson.data.ad_list.length", "equals": 0 },
        { "path": "bodyJson.data.user.name", "equals": "ok" },
        { "path": "bodyJson.data.interval", "equals": 31536000 }
      ]
    },
    {
      "name": "Generic startup cleanup preserves normal campaign content",
      "script": "startup-ad-clean.js",
      "url": "https://example.com/launch/config",
      "body": {
        "data": {
          "campaign": {
            "name": "summer",
            "items": [
              { "id": 1, "title": "normal activity" },
              { "id": 2, "is_ad": true, "title": "ad activity" }
            ]
          },
          "commercial": {
            "name": "member benefits"
          }
        }
      },
      "assertions": [
        { "path": "bodyJson.data.campaign.name", "equals": "summer" },
        { "path": "bodyJson.data.campaign.items.length", "equals": 1 },
        { "path": "bodyJson.data.campaign.items.0.id", "equals": 1 },
        { "path": "bodyJson.data.commercial.name", "equals": "member benefits" }
      ]
    },
    {
      "name": "Generic startup cleanup removes explicit promotion ad object",
      "script": "startup-ad-clean.js",
      "url": "https://example.com/startup/config",
      "body": {
        "data": {
          "promotion": {
            "type": "ad",
            "creative_id": "abc",
            "image": "https://example.com/ad.png"
          }
        }
      },
      "assertions": [
        { "path": "bodyJson.data.promotion", "equals": {} }
      ]
    },
    {
      "name": "Coolapk feed ads are filtered",
      "script": "coolapk-clean.js",
      "url": "https://api.coolapk.com/v6/dataList",
      "body": {
        "data": [
          { "id": 1, "title": "normal" },
          { "id": 2, "isAd": true, "title": "normal ad card" },
          { "id": 945, "title": "known ad" }
        ]
      },
      "assertions": [
        { "path": "bodyJson.data.length", "equals": 1 },
        { "path": "bodyJson.data.0.id", "equals": 1 }
      ]
    },
    {
      "name": "Pangolin request gets no-fill response",
      "script": "ad-sdk-no-fill.js",
      "url": "https://api-access.pangolin-sdk-toutiao.com/api/ad/union/sdk/get_ads/?x=1",
      "hasResponse": false,
      "assertions": [
        { "path": "result.response.status", "equals": 200 },
        { "path": "responseBodyJson.status_code", "equals": 20001 }
      ]
    },
    {
      "name": "GDT response gets no-fill body",
      "script": "ad-sdk-no-fill.js",
      "url": "https://win.gdt.qq.com/gdt_mview.fcg?x=1",
      "body": {
        "old": true
      },
      "assertions": [
        { "path": "bodyJson.ret", "equals": 102006 },
        { "path": "bodyJson.data", "equals": {} }
      ]
    }
  ]
}
