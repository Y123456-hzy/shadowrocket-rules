    },
    {
      "id": "scoped-http-engine-hosts",
      "source_ids": ["blackmatrix7-allinone"],
      "local_evidence": "force-http-engine-hosts uses %APPEND%, exact hosts, no wildcard, and matches the MITM host list"
    },
    {
      "id": "script-body-metadata",
      "source_ids": ["app2smile-modules", "blackmatrix7-allinone"],
      "local_evidence": "response scripts declare requires-body, max-size, timeout, raw script-path, and script-update-interval metadata"
    },
    {
      "id": "narrow-app-specific-rules",
      "source_ids": ["app2smile-modules"],
      "local_evidence": "known Bilibili splash/feed/tab, nested Bilibili banner/game feed cards, and Coolapk endpoints use app-specific script patterns before generic startup cleanup"
    },
    {
      "id": "exact-startup-url-rewrite",
      "source_ids": ["blackmatrix7-allinone", "bai1zi-shadowrocket"],
      "local_evidence": "mime.baidu.com/v*/IosStart/getStartInfo is a single exact URL Rewrite with exact HTTP-engine and MITM host scope"
    },
    {
