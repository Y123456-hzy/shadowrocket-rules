      "local_evidence": "fixture cases cover Bilibili, Coolapk, generic startup cleanup, no-fill responses, and false-positive guards"
    },
    {
      "id": "remote-release-drift-check",
      "source_ids": ["johnshall-release"],
      "local_evidence": "remote release check verifies raw module/script reachability plus SHA-256 content equality"
    },
    {
      "id": "remote-reference-source-check",
